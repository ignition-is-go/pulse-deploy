# Managed by Ansible — cx6_sriov role
# CX6 OVS bridges with bonded uplinks
{% for card in cx6_cards %}

{% for pf in card.pf_ifaces %}
auto {{ pf }}
iface {{ pf }} inet manual

{% endfor %}
auto {{ card.bridge }}
iface {{ card.bridge }} inet manual
    ovs_type OVSBridge
    ovs_ports {{ card.bond }}
    ovs_mtu {{ cx6_ovs_mtu }}

auto {{ card.bond }}
iface {{ card.bond }} inet manual
    ovs_type OVSBond
    ovs_bonds {{ card.pf_ifaces | join(' ') }}
    ovs_bridge {{ card.bridge }}
    ovs_mtu {{ cx6_ovs_mtu }}
    ovs_options lacp=active bond_mode=balance-tcp
{% endfor %}

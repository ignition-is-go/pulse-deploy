# Managed by Ansible — pve_cx6_sriov role
# CX6 OVS bridges with single PF uplink (no bonding)
# Uplink PF auto-detected at role runtime
{% for card in cx6_cards %}
{% set uplink = cx6_uplinks | selectattr('bridge', 'eq', card.bridge) | map(attribute='uplink') | first %}

auto {{ card.bridge }}
iface {{ card.bridge }} inet manual
    ovs_type OVSBridge
    ovs_ports {{ uplink }}
    ovs_mtu {{ cx6_ovs_mtu }}

auto {{ uplink }}
iface {{ uplink }} inet manual
    ovs_type OVSPort
    ovs_bridge {{ card.bridge }}
    ovs_mtu {{ cx6_ovs_mtu }}
{% endfor %}

---
# Copy this file to vault.yml and fill in real values:
#   cp vault.yml.example vault.yml
#
# vault.yml is gitignored — secrets never touch the repo.

vault_win_user: Administrator
vault_win_password: "CHANGEME"
vault_linux_user: root
vault_linux_password: "CHANGEME"
vault_plastic_api_key: "CHANGEME"
vault_plastic_cloud_user: "user@email.com"
vault_plastic_cloud_org: "OrgName"
vault_render_server_url: "ws://192.168.1.158:3000/api/ws"
